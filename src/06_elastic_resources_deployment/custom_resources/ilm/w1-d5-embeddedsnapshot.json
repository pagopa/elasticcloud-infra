{
  "hot": {
    "minAge": "0ms",
    "rollover": {
      "maxPrimarySize": "20gb",
      "maxAge": "1d",
      "minPrimarySize": "5gb"

    }
  },
  "warm": {
    "minAge": "0ms",
    "setPriority": 50,
    "shrink": {
      "maxPrimarySize": "65gb",
      "allowWriteAfterShrink": true
    }
  },
  "delete": {
    "minAge": "5d",
    "deleteSearchableSnapshot": true,
    "waitForSnapshot": "cloud-snapshot-policy"
  }
}
